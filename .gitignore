# Local-only per global policy
CLAUDE.md
.claude/
crosslog.md
sessions/

# Launch/marketing material — drafts + personal photos (real inventory, etc.).
# Local-only; never published to the public repo.
article/

# OS
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
*.env.local

# Worktrees (just in case anything ends up below the project root)
.worktrees/

# Node deps
node_modules/

# Helper PDF render scratch (Edge headless tmp + last-rendered PDF)
.tmp/

# Clean-test instance: throwaway data dir + Edge profile + state, created by
# scripts/test-clean.ps1 and wiped on `-Action destroy`. Never committed.
.test-instance/

# Tauri build artifacts (Rust target, generated schemas, bundled sidecar binary)
src-tauri/target/
src-tauri/gen/
src-tauri/binaries/
dist-sidecar/

# Per-install user data — generated/edited at runtime, never committed.
# (The canonical location is %APPDATA%\Haspel\data\ on Windows, etc.;
# see helper/index.mjs getUserDataDir(). These ignores stop a stray
# `git add` from re-tracking them if someone runs an older helper that
# still writes to <repo>/data/.)
data/ai-cache.json
data/brand-logos.json
